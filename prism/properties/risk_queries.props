// Core mission outcomes under best/worst route choices
Pmax=? [ F "success" ]
Pmin=? [ F "success" ]
Pmax=? [ F "failure" ]
Pmin=? [ F "failure" ]

// Bounded-time (step) outcome checks
Pmax=? [ F<=3 "success" ]
Pmin=? [ F<=3 "success" ]
Pmax=? [ F<=3 "failure" ]
Pmin=? [ F<=3 "failure" ]

// Is there some route policy that achieves at least 90% eventual success?
!(P<0.90 [ F "success" ])
